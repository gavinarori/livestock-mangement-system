// prisma/schema.prisma — full schema including Resource Management models
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  MANAGER
  VETERINARIAN
  WORKER
  VIEWER
}

enum AnimalType {
  CATTLE
  SHEEP
  GOAT
  PIG
  POULTRY
  HORSE
  FISH
  AQUATIC
  OTHER
}

enum AnimalGender {
  MALE
  FEMALE
  OTHER
}

enum HealthStatus {
  HEALTHY
  SICK
  INJURED
  RECOVERING
  DECEASED
}

enum VaccinationStatus {
  NOT_VACCINATED
  PARTIALLY_VACCINATED
  FULLY_VACCINATED
  BOOSTER_DUE
  OVERDUE
}

enum DiseaseCategory {
  INFECTIOUS
  GENETIC
  NUTRITIONAL
  ENVIRONMENTAL
  PARASITIC
  OTHER
}

enum DiseaseTrend {
  RISING
  STABLE
  FALLING
}

enum DiseaseSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TreatmentStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TreatmentPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum VaccinationScheduleStatus {
  UPCOMING
  OVERDUE
  COMPLETED
  SKIPPED
}

enum VetAvailabilityStatus {
  AVAILABLE
  BUSY
  OFF_DUTY
  ON_LEAVE
}

enum BreedingOutcome {
  PENDING
  SUCCESSFUL
  UNSUCCESSFUL
}

enum BreedingMethod {
  NATURAL
  ARTIFICIAL_INSEMINATION
  EMBRYO_TRANSFER
}

enum HeatCycleStatus {
  ACTIVE
  EXPECTED
  OVERDUE
  BRED
}

// Resource Management enums
enum EquipmentStatus {
  OPERATIONAL
  MAINTENANCE
  REPAIR
  RETIRED
}

enum FeedType {
  DAIRY
  POULTRY
  PIG
  CATTLE
  SHEEP
  GOAT
  ROUGHAGE
  SUPPLEMENT
  CONCENTRATE
  OTHER
}

enum MedicineCategory {
  ANTIBIOTIC
  VACCINE
  DEWORMER
  SUPPLEMENT
  PESTICIDE
  TREATMENT
  ANTIFUNGAL
  ANTIPARASITIC
  HORMONE
  OTHER
}

enum StockTransactionType {
  RESTOCK
  CONSUME
  ADJUST
  DISPOSE
  TRANSFER
}

enum EquipmentEventType {
  SERVICE
  REPAIR
  INSPECTION
  INCIDENT
  UPGRADE
  RETIREMENT
}


enum ShareType {
  PUBLIC
  PRIVATE
  ROLE_BASED
}

enum ShareRole {
  VET
  INSPECTOR
  BUYER
  PARTNER
  ADMIN
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  DONE
  OVERDUE
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskCategory {
  FEEDING
  CLEANING
  MEDICATION
  VACCINATION
  INSPECTION
  BREEDING
  EQUIPMENT
  OTHER
}

// ─── Organization ─────────────────────────────────────────────────────────────

model Organization {
  id           String  @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  slug         String  @unique
  description  String?
  logo         String?
  subscription String  @default("free")
  maxAnimals   Int     @default(100)
  maxMembers   Int     @default(5)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  members              User[]
  animals              Animal[]
  healthRecords        HealthRecord[]
  veterinaryNotes      VeterinaryNote[]
  breedings            Breeding[]
  heatCycles           HeatCycle[]
  shares               AnimalShare[]
  vaccinationSchedules VaccinationSchedule[]
  diseaseOutbreaks     DiseaseOutbreak[]
  treatments           Treatment[]
  vetProfiles          VetProfile[]

  // Resource management
  feedItems           FeedItem[]
  medicineItems       MedicineItem[]
  equipmentItems      EquipmentItem[]
  stockTransactions   StockTransaction[]
  equipmentEvents     EquipmentEvent[]
  tasks               Task[]



}

// ─── User ─────────────────────────────────────────────────────────────────────

model User {
  id             String       @id @default(auto()) @map("_id") @db.ObjectId
  email          String       @unique
  name           String
  password       String
  role           UserRole     @default(VIEWER)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String       @db.ObjectId
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  createdBreedings  Breeding[]  @relation("BreedingCreatedBy")
  updatedBreedings  Breeding[]  @relation("BreedingUpdatedBy")
  createdHeatCycles HeatCycle[] @relation("HeatCycleCreatedBy")

  createdHealthRecords        HealthRecord[]        @relation("HealthRecordCreatedBy")
  updatedHealthRecords        HealthRecord[]        @relation("HealthRecordUpdatedBy")
  createdVaccinationSchedules VaccinationSchedule[] @relation("VaccScheduleCreatedBy")
  updatedVaccinationSchedules VaccinationSchedule[] @relation("VaccScheduleUpdatedBy")
  createdDiseaseOutbreaks     DiseaseOutbreak[]     @relation("DiseaseOutbreakCreatedBy")
  updatedDiseaseOutbreaks     DiseaseOutbreak[]     @relation("DiseaseOutbreakUpdatedBy")
  createdTreatments           Treatment[]           @relation("TreatmentCreatedBy")
  updatedTreatments           Treatment[]           @relation("TreatmentUpdatedBy")

  // Resource management audit
  createdFeedItems      FeedItem[]         @relation("FeedCreatedBy")
  updatedFeedItems      FeedItem[]         @relation("FeedUpdatedBy")
  createdMedicineItems  MedicineItem[]     @relation("MedicineCreatedBy")
  updatedMedicineItems  MedicineItem[]     @relation("MedicineUpdatedBy")
  createdEquipmentItems EquipmentItem[]    @relation("EquipmentCreatedBy")
  updatedEquipmentItems EquipmentItem[]    @relation("EquipmentUpdatedBy")
  stockTransactions     StockTransaction[] @relation("StockTransactionBy")
  equipmentEvents       EquipmentEvent[]   @relation("EquipmentEventBy")
  assignedTasks  Task[]  @relation("TaskAssignedTo")
  createdTasks   Task[]  @relation("TaskCreatedBy")

  createdShares       AnimalShare[]      @relation("ShareCreator")

  @@index([organizationId])
}

// ─── Animal ───────────────────────────────────────────────────────────────────

model Animal {
  id               String       @id @default(auto()) @map("_id") @db.ObjectId
  name             String
  type             AnimalType
  breed            String
  dateOfBirth      DateTime
  gender           AnimalGender
  identificationId String?
  healthStatus     HealthStatus @default(HEALTHY)

  weight        Float?
  height        Float?
  color         String?
  distinctMarks String?
  notes         String?
  location      String?

  acquisitionDate  DateTime?
  acquisitionPrice Float?
  inbreedingCoeff  Float?   @default(0)

  parentMale     Animal?  @relation("OffspringMale", fields: [parentMaleId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  parentMaleId   String?  @db.ObjectId
  parentFemale   Animal?  @relation("OffspringFemale", fields: [parentFemaleId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  parentFemaleId String?  @db.ObjectId

  offspring       Animal[] @relation("OffspringMale")
  offspringFemale Animal[] @relation("OffspringFemale")

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String       @db.ObjectId

  healthRecords        HealthRecord[]
  veterinaryNotes      VeterinaryNote[]
  breedingsAsDam       Breeding[]             @relation("BreedingDam")
  breedingsAsSire      Breeding[]             @relation("BreedingSire")
  heatCycles           HeatCycle[]
  shares               AnimalShare[]
  vaccinationSchedules VaccinationSchedule[]
  diseaseOutbreakLinks DiseaseOutbreakAnimal[]
  treatments           Treatment[]
  tasks                Task[]


  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([type])
  @@index([gender])
  @@index([healthStatus])
}

// ─── Feed Item ────────────────────────────────────────────────────────────────
// Tracks livestock feed inventory with full stock management

model FeedItem {
  id             String       @id @default(auto()) @map("_id") @db.ObjectId
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String       @db.ObjectId

  name          String
  type          FeedType      // dairy | poultry | pig | cattle | roughage | supplement | concentrate | other
  quantityKg    Float         @default(0)  // current stock in kg
  minimumKg     Float         @default(0)  // reorder threshold
  maximumKg     Float?        // max storage capacity
  costPerKg     Float         // in KSH
  totalValue    Float         @default(0)  // computed: quantityKg * costPerKg

  supplier      String?
  supplierPhone String?
  supplierEmail String?

  lastRestocked DateTime?
  expiryDate    DateTime?
  batchNumber   String?
  storageLocation String?
  notes         String?

  // Nutritional info (optional)
  proteinPct  Float?
  energyMcal  Float?
  moisturePct Float?

  isActive    Boolean @default(true)

  stockTransactions StockTransaction[] @relation("FeedTransactions")

  createdBy   User?    @relation("FeedCreatedBy", fields: [createdById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdById String?  @db.ObjectId
  updatedBy   User?    @relation("FeedUpdatedBy", fields: [updatedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  updatedById String?  @db.ObjectId

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([type])
  @@index([quantityKg])
  @@index([expiryDate])
}

// ─── Medicine Item ────────────────────────────────────────────────────────────

model MedicineItem {
  id             String       @id @default(auto()) @map("_id") @db.ObjectId
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String       @db.ObjectId

  name          String
  category      MedicineCategory
  quantity      Float
  unit          String         // bottles | vials | doses | packs | tubes | containers | kg | litre | sachets
  minimumQty    Float          @default(0)
  maximumQty    Float?

  costPerUnit   Float?         // in KSH
  totalValue    Float?         // computed: quantity * costPerUnit

  expiryDate    DateTime?
  batchNumber   String?
  usageCount    Int     @default(0)

  supplier      String?
  supplierPhone String?
  manufacturer  String?
  licenseNo     String?        // pharmaceutical license

  storageTemp   String?        // refrigerated | cool-dry | room-temp
  storageLocation String?
  prescription  Boolean @default(false)   // requires prescription
  withdrawalDays Int?   // pre-slaughter withdrawal period in days

  activeIngredient String?
  dosageInstructions String?
  notes           String?
  isActive        Boolean @default(true)

  stockTransactions StockTransaction[] @relation("MedicineTransactions")

  createdBy   User?    @relation("MedicineCreatedBy", fields: [createdById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdById String?  @db.ObjectId
  updatedBy   User?    @relation("MedicineUpdatedBy", fields: [updatedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  updatedById String?  @db.ObjectId

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([category])
  @@index([expiryDate])
  @@index([quantity])
}

// ─── Equipment Item ───────────────────────────────────────────────────────────

model EquipmentItem {
  id             String       @id @default(auto()) @map("_id") @db.ObjectId
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String       @db.ObjectId

  name           String
  type           String          // dairy | poultry | processing | utility | vehicle | feeding | medical | other
  status         EquipmentStatus @default(OPERATIONAL)

  serialNumber   String?
  model          String?
  manufacturer   String?
  purchaseDate   DateTime?
  purchaseCost   Float?         // in KSH
  currentValue   Float?         // estimated current value KSH

  lastServiceDate DateTime?
  nextServiceDate DateTime?
  serviceIntervalDays Int?       // how often to service in days
  usageHours     Float?  @default(0)
  maxUsageHours  Float?          // hours until major overhaul

  assignedTo     String?
  location       String?
  warrantyExpiry DateTime?
  insuranceNo    String?

  supplier      String?
  supplierPhone String?

  maintenanceNotes String?
  notes            String?
  isActive         Boolean @default(true)

  equipmentEvents EquipmentEvent[]

  createdBy   User?    @relation("EquipmentCreatedBy", fields: [createdById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdById String?  @db.ObjectId
  updatedBy   User?    @relation("EquipmentUpdatedBy", fields: [updatedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  updatedById String?  @db.ObjectId

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([type])
  @@index([status])
  @@index([nextServiceDate])
}

// ─── Stock Transaction ────────────────────────────────────────────────────────
// Audit log of every stock movement (feed or medicine)

model StockTransaction {
  id             String       @id @default(auto()) @map("_id") @db.ObjectId
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String       @db.ObjectId

  type           StockTransactionType  // RESTOCK | CONSUME | ADJUST | DISPOSE | TRANSFER
  resourceType   String                // feed | medicine
  feedItemId     String?  @db.ObjectId
  medicineItemId String?  @db.ObjectId

  feedItem     FeedItem?     @relation("FeedTransactions", fields: [feedItemId], references: [id], onDelete: SetNull)
  medicineItem MedicineItem? @relation("MedicineTransactions", fields: [medicineItemId], references: [id], onDelete: SetNull)

  quantityBefore Float
  quantityChange Float       // positive = added, negative = removed
  quantityAfter  Float
  costPerUnit    Float?      // KSH at time of transaction
  totalCost      Float?      // KSH total

  reason         String?     // e.g. "Morning feeding", "Treatment for animal X"
  referenceId    String?     // e.g. Treatment ID or vaccination ID
  batchNumber    String?
  notes          String?

  performedBy   User     @relation("StockTransactionBy", fields: [performedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  performedById String   @db.ObjectId

  createdAt DateTime @default(now())

  @@index([organizationId])
  @@index([feedItemId])
  @@index([medicineItemId])
  @@index([type])
  @@index([createdAt])
}

// ─── Equipment Event ──────────────────────────────────────────────────────────
// Audit log of all equipment service/repair/inspection events

model EquipmentEvent {
  id             String       @id @default(auto()) @map("_id") @db.ObjectId
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String       @db.ObjectId

  equipment      EquipmentItem @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  equipmentId    String        @db.ObjectId

  eventType      EquipmentEventType  // SERVICE | REPAIR | INSPECTION | INCIDENT | UPGRADE | RETIREMENT
  eventDate      DateTime
  description    String
  cost           Float?              // KSH
  technicianName String?
  nextActionDate DateTime?
  hoursAtEvent   Float?
  notes          String?

  performedBy   User     @relation("EquipmentEventBy", fields: [performedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  performedById String   @db.ObjectId

  createdAt DateTime @default(now())

  @@index([equipmentId])
  @@index([organizationId])
  @@index([eventDate])
}

// ─── Health Models ────────────────────────────────────────────────────────────

model HealthRecord {
  id             String       @id @default(auto()) @map("_id") @db.ObjectId
  animal         Animal       @relation(fields: [animalId], references: [id], onDelete: Cascade)
  animalId       String       @db.ObjectId
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String       @db.ObjectId

  recordType   String
  description  String
  date         DateTime
  recordedBy   String
  recordedById String?  @db.ObjectId

  vaccineName       String?
  vaccinationStatus VaccinationStatus?
  nextDueDate       DateTime?
  diagnosis         String?
  diseaseCategory   DiseaseCategory?
  severity          String?
  treatment         String?
  outcome           String?
  temperature       Float?
  weight            Float?
  veterinarianId    String?  @db.ObjectId
  veterinarianName  String?
  notes             String?
  attachments       String[]

  createdBy   User?    @relation("HealthRecordCreatedBy", fields: [createdById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdById String?  @db.ObjectId
  updatedBy   User?    @relation("HealthRecordUpdatedBy", fields: [updatedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  updatedById String?  @db.ObjectId

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([animalId])
  @@index([organizationId])
  @@index([date])
  @@index([recordType])
}

model VeterinaryNote {
  id               String       @id @default(auto()) @map("_id") @db.ObjectId
  animal           Animal       @relation(fields: [animalId], references: [id], onDelete: Cascade)
  animalId         String       @db.ObjectId
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId   String       @db.ObjectId
  veterinarianId   String?  @db.ObjectId
  veterinarianName String?
  date             DateTime
  examination      String
  diagnosis        String?
  recommendations  String
  prescriptions    String?
  followUpDate     DateTime?
  notes            String?
  attachments      String[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([animalId])
  @@index([organizationId])
}

model VaccinationSchedule {
  id               String                    @id @default(auto()) @map("_id") @db.ObjectId
  animal           Animal                    @relation(fields: [animalId], references: [id], onDelete: Cascade)
  animalId         String                    @db.ObjectId
  organization     Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId   String                    @db.ObjectId
  vaccineName      String
  vaccineType      String
  dueDate          DateTime
  administeredAt   DateTime?
  status           VaccinationScheduleStatus @default(UPCOMING)
  batchNumber      String?
  dosage           String?
  route            String?
  manufacturer     String?
  expiryDate       DateTime?
  nextBoosterDate  DateTime?
  assignedVetId    String?  @db.ObjectId
  assignedVetName  String?
  administeredById   String? @db.ObjectId
  administeredByName String?
  sideEffects      String?
  notes            String?
  attachments      String[]
  createdBy        User?    @relation("VaccScheduleCreatedBy", fields: [createdById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdById      String?  @db.ObjectId
  updatedBy        User?    @relation("VaccScheduleUpdatedBy", fields: [updatedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  updatedById      String?  @db.ObjectId
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([animalId])
  @@index([organizationId])
  @@index([dueDate])
  @@index([status])
}

model DiseaseOutbreak {
  id                    String          @id @default(auto()) @map("_id") @db.ObjectId
  organization          Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId        String          @db.ObjectId
  name                  String
  category              DiseaseCategory
  severity              DiseaseSeverity
  trend                 DiseaseTrend    @default(STABLE)
  firstCaseDate         DateTime
  lastCaseDate          DateTime
  isActive              Boolean         @default(true)
  quarantineActive      Boolean         @default(false)
  quarantineZone        String?
  containmentNotes      String?
  treatmentProtocol     String?
  preventionMeasures    String?
  labReference          String?
  reportedToAuthorities Boolean         @default(false)
  affectedAnimals       DiseaseOutbreakAnimal[]
  notes                 String?
  createdBy             User?    @relation("DiseaseOutbreakCreatedBy", fields: [createdById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdById           String?  @db.ObjectId
  updatedBy             User?    @relation("DiseaseOutbreakUpdatedBy", fields: [updatedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  updatedById           String?  @db.ObjectId
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([organizationId])
  @@index([severity])
  @@index([isActive])
}

model DiseaseOutbreakAnimal {
  id           String          @id @default(auto()) @map("_id") @db.ObjectId
  outbreak     DiseaseOutbreak @relation(fields: [outbreakId], references: [id], onDelete: Cascade)
  outbreakId   String          @db.ObjectId
  animal       Animal          @relation(fields: [animalId], references: [id], onDelete: Cascade)
  animalId     String          @db.ObjectId
  dateAffected DateTime
  recoveredAt  DateTime?
  isRecovered  Boolean         @default(false)
  notes        String?

  @@index([outbreakId])
  @@index([animalId])
}

model Treatment {
  id               String            @id @default(auto()) @map("_id") @db.ObjectId
  animal           Animal            @relation(fields: [animalId], references: [id], onDelete: Cascade)
  animalId         String            @db.ObjectId
  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId   String            @db.ObjectId
  condition        String
  status           TreatmentStatus   @default(PENDING)
  priority         TreatmentPriority @default(MEDIUM)
  startDate        DateTime
  endDate          DateTime?
  completedAt      DateTime?
  medication       String?
  dosage           String?
  frequency        String?
  route            String?
  temperature      Float?
  weight           Float?
  assignedVetId    String?  @db.ObjectId
  assignedVetName  String?
  steps            Json?
  diagnosisSource  String?
  labReference     String?
  isolationRequired Boolean  @default(false)
  isolationLocation String?
  followUpDate     DateTime?
  notes            String?
  attachments      String[]
  createdBy        User?    @relation("TreatmentCreatedBy", fields: [createdById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdById      String?  @db.ObjectId
  updatedBy        User?    @relation("TreatmentUpdatedBy", fields: [updatedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  updatedById      String?  @db.ObjectId
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([animalId])
  @@index([organizationId])
  @@index([status])
  @@index([priority])
}

model VetProfile {
  id               String                @id @default(auto()) @map("_id") @db.ObjectId
  organization     Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId   String                @db.ObjectId
  userId           String?  @db.ObjectId
  name             String
  email            String?
  phone            String?
  speciality       String
  licenseNo        String?
  availability     VetAvailabilityStatus @default(AVAILABLE)
  currentCaseCount Int                   @default(0)
  isExternal       Boolean               @default(false)
  isActive         Boolean               @default(true)
  clinicName       String?
  clinicAddress    String?
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([organizationId])
  @@index([availability])
}

model Breeding {
  id                 String          @id @default(auto()) @map("_id") @db.ObjectId
  dam                Animal          @relation("BreedingDam", fields: [damId], references: [id], onDelete: Cascade)
  damId              String          @db.ObjectId
  sire               Animal          @relation("BreedingSire", fields: [sireId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  sireId             String          @db.ObjectId
  organization       Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId     String          @db.ObjectId
  breedingDate       DateTime
  method             BreedingMethod  @default(NATURAL)
  outcome            BreedingOutcome @default(PENDING)
  offspringCount     Int?
  expectedBirthDate  DateTime?
  actualBirthDate    DateTime?
  inbreedingCoeff    Float?          @default(0)
  confirmedPregnancy Boolean?        @default(false)
  pregnancyCheckDate DateTime?
  veterinarian       String?
  location           String?
  notes              String?
  attachments        String[]
  createdBy          User     @relation("BreedingCreatedBy", fields: [createdById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdById        String   @db.ObjectId
  updatedBy          User?    @relation("BreedingUpdatedBy", fields: [updatedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  updatedById        String?  @db.ObjectId
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([damId])
  @@index([sireId])
  @@index([organizationId])
}

model HeatCycle {
  id               String          @id @default(auto()) @map("_id") @db.ObjectId
  animal           Animal          @relation(fields: [animalId], references: [id], onDelete: Cascade)
  animalId         String          @db.ObjectId
  organization     Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId   String          @db.ObjectId
  lastHeatDate     DateTime
  nextExpectedDate DateTime
  cycleLengthDays  Int             @default(21)
  status           HeatCycleStatus @default(EXPECTED)
  intensity        String?
  observedBy       String?
  notes            String?
  createdBy        User     @relation("HeatCycleCreatedBy", fields: [createdById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdById      String   @db.ObjectId
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([animalId])
  @@index([organizationId])
  @@index([status])
}



model AnimalShare {
  id               String    @id @default(auto()) @map("_id") @db.ObjectId
  animalId         String    @db.ObjectId
  organizationId   String    @db.ObjectId
  createdBy        String    @db.ObjectId

  shareType        ShareType @default(PUBLIC)
  token            String    @unique
  passwordHash     String?

  // Role-based access
  shareRole        ShareRole?
  allowedEmails    String[]  @default([])

  // Permissions matrix (which data sections are visible)
  canViewHealth        Boolean @default(true)
  canViewBreeding      Boolean @default(false)
  canViewVeterinary    Boolean @default(false)
  canViewFinancials    Boolean @default(false)
  canViewLineage       Boolean @default(false)
  canViewCertificates  Boolean @default(false)

  // Lifecycle
  expiresAt        DateTime
  isRevoked        Boolean   @default(false)
  revokedAt        DateTime?
  revokedBy        String?   @db.ObjectId

  // Stats
  viewCount        Int       @default(0)
  lastAccessedAt   DateTime?



  // Notes
  label            String?

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Relations
  animal           Animal        @relation(fields: [animalId], references: [id], onDelete: Cascade)
  organization     Organization  @relation(fields: [organizationId], references: [id])
  creator          User          @relation("ShareCreator", fields: [createdBy], references: [id])
  accessLogs       ShareAccessLog[]

  @@map("animal_shares")
}

model ShareAccessLog {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  shareId     String    @db.ObjectId
  userId      String?   @db.ObjectId

  ip          String?
  userAgent   String?
  country     String?
  city        String?

  accessedAt  DateTime  @default(now())
  duration    Int?      // seconds spent on page

  share       AnimalShare @relation(fields: [shareId], references: [id], onDelete: Cascade)

  @@map("share_access_logs")
}


model Task {
  id             String       @id @default(auto()) @map("_id") @db.ObjectId
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String       @db.ObjectId

  title          String
  description    String?
  category       TaskCategory @default(OTHER)
  status         TaskStatus   @default(PENDING)
  priority       TaskPriority @default(MEDIUM)

  // Who the task is assigned to (a WORKER user)
  assignedTo     User?    @relation("TaskAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)
  assignedToId   String?  @db.ObjectId
  assignedToName String?

  // Optional animal link
  animal         Animal?  @relation(fields: [animalId], references: [id], onDelete: SetNull)
  animalId       String?  @db.ObjectId

  dueDate        DateTime?
  completedAt    DateTime?
  notes          String?

  // Who created (MANAGER or ADMIN)
  createdBy      User?    @relation("TaskCreatedBy", fields: [createdById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdById    String?  @db.ObjectId
  createdByName  String?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId])
  @@index([assignedToId])
  @@index([status])
  @@index([dueDate])
  @@index([animalId])
}
